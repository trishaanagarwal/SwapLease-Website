rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    // value is a string within an inclusive length range
    function strLen(v, min, max) {
      return v is string && v.size() >= min && v.size() <= max;
    }

    // ---------- users ----------
    // Public read (names shown on listings); only the owner may write their own doc.
    match /users/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && strLen(request.resource.data.name, 1, 100)
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 320;

      // Profile edits: cannot change email or uid; bounded field sizes.
      allow update: if isOwner(userId)
        && request.resource.data.email == resource.data.email
        && strLen(request.resource.data.name, 1, 100)
        && (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 1000)
        && (!('phone' in request.resource.data) || request.resource.data.phone.size() <= 40)
        && (!('university' in request.resource.data) || request.resource.data.university.size() <= 120);

      allow delete: if false;
    }

    // ---------- listings ----------
    // Public read; create only as yourself; update/delete only by owner.
    match /listings/{listingId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && strLen(request.resource.data.title, 1, 200)
        && request.resource.data.rent is number
        && request.resource.data.rent > 0
        && request.resource.data.rent < 100000
        && request.resource.data.status == 'active'
        && request.resource.data.images is list
        && request.resource.data.images.size() <= 12
        && (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000);

      // Owner-only edits; ownership and creation time are immutable.
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ---------- conversations ----------
    // Only the two participants can see or touch a conversation.
    match /conversations/{convId} {
      allow read, update: if signedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2;

      allow delete: if false;

      // ---------- messages ----------
      match /messages/{msgId} {
        function participants() {
          return get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        }
        allow read: if signedIn() && request.auth.uid in participants();

        allow create: if signedIn()
          && request.auth.uid in participants()
          && request.resource.data.senderId == request.auth.uid
          && strLen(request.resource.data.content, 1, 2000);

        allow update, delete: if false;
      }
    }
  }
}
