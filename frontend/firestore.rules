rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    // Email-verified (Google sign-ins are verified by the provider).
    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }
    // value is a string within an inclusive length range
    function strLen(v, min, max) {
      return v is string && v.size() >= min && v.size() <= max;
    }

    // ---------- users ----------
    // Readable by signed-in users only (docs contain email/phone, so they must
    // not be publicly scrapeable); only the owner may write their own doc.
    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isOwner(userId)
        && strLen(request.resource.data.name, 1, 100)
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 320;

      // Profile edits: email may only stay the same OR be synced to the
      // user's own verified Auth email (after a confirmed email change).
      allow update: if isOwner(userId)
        && (request.resource.data.email == resource.data.email
            || request.resource.data.email == request.auth.token.email)
        && strLen(request.resource.data.name, 1, 100)
        && (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 1000)
        && (!('phone' in request.resource.data) || request.resource.data.phone.size() <= 40)
        && (!('university' in request.resource.data) || request.resource.data.university.size() <= 120)
        && (!('photoURL' in request.resource.data) || request.resource.data.photoURL.size() <= 600)
        && (!('bookmarks' in request.resource.data)
            || (request.resource.data.bookmarks is list && request.resource.data.bookmarks.size() <= 1000));

      // The owner may delete their own profile (account deletion).
      allow delete: if isOwner(userId);
    }

    // ---------- listings ----------
    // Public read; create only as yourself; update/delete only by owner.
    match /listings/{listingId} {
      allow read: if true;

      allow create: if verified()
        && request.resource.data.userId == request.auth.uid
        && strLen(request.resource.data.title, 1, 200)
        && request.resource.data.rent is number
        && request.resource.data.rent > 0
        && request.resource.data.rent < 100000
        && request.resource.data.status == 'active'
        && request.resource.data.images is list
        && request.resource.data.images.size() <= 12
        && (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000)
        && (!('onBehalfOf' in request.resource.data)
            || request.resource.data.onBehalfOf == null
            || strLen(request.resource.data.onBehalfOf, 1, 60))
        && (!('contactLink' in request.resource.data)
            || request.resource.data.contactLink == null
            || strLen(request.resource.data.contactLink, 1, 200));

      // Owner-only edits; ownership and creation time are immutable, and the
      // same field constraints as create are re-validated to prevent tampering.
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && strLen(request.resource.data.title, 1, 200)
        && request.resource.data.rent is number
        && request.resource.data.rent > 0
        && request.resource.data.rent < 100000
        && request.resource.data.status in ['active', 'taken']
        && request.resource.data.images is list
        && request.resource.data.images.size() <= 12
        && (!('description' in request.resource.data) || request.resource.data.description.size() <= 5000)
        && (!('onBehalfOf' in request.resource.data)
            || request.resource.data.onBehalfOf == null
            || strLen(request.resource.data.onBehalfOf, 1, 60))
        && (!('contactLink' in request.resource.data)
            || request.resource.data.contactLink == null
            || strLen(request.resource.data.contactLink, 1, 200));

      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    // ---------- seekers (roommate posts, one per user, doc id = uid) ----------
    match /seekers/{userId} {
      allow read: if true;
      allow write: if verified() && request.auth.uid == userId
        && request.resource.data.userId == userId
        && strLen(request.resource.data.about, 1, 2000)
        && request.resource.data.images is list
        && request.resource.data.images.size() <= 4
        && (!('budget' in request.resource.data)
            || (request.resource.data.budget is number
                && request.resource.data.budget >= 0
                && request.resource.data.budget < 100000))
        && (!('onBehalfOf' in request.resource.data)
            || request.resource.data.onBehalfOf == null
            || strLen(request.resource.data.onBehalfOf, 1, 60));
      allow delete: if isOwner(userId);
    }

    // ---------- reports ----------
    // Signed-in users can file a report; only admins read them (via console).
    match /reports/{reportId} {
      allow read, update, delete: if false;
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && strLen(request.resource.data.listingId, 1, 200)
        && strLen(request.resource.data.reason, 1, 1000);
    }

    // ---------- conversations ----------
    // Only the two participants can see or touch a conversation.
    match /conversations/{convId} {
      allow read: if signedIn()
        && request.auth.uid in resource.data.participants;

      // Participants and creation time are immutable after creation.
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.createdAt == resource.data.createdAt;

      allow create: if verified()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2;

      allow delete: if false;

      // ---------- messages ----------
      match /messages/{msgId} {
        function participants() {
          return get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        }
        allow read: if signedIn() && request.auth.uid in participants();

        allow create: if verified()
          && request.auth.uid in participants()
          && request.resource.data.senderId == request.auth.uid
          && strLen(request.resource.data.content, 1, 2000);

        allow update, delete: if false;
      }
    }
  }
}
