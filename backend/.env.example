# Copy these into Railway → your project → Variables

# Required: generate a long random string (e.g. open a password manager and create a 32-char password)
JWT_SECRET=replace-with-a-long-random-secret

# Required: your Resend API key from resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Required: the URL Vercel gives you after deploying the frontend (no trailing slash)
FRONTEND_URL=https://your-frontend.vercel.app

# Required: the URL Railway gives you after deploying the backend (no trailing slash)
BACKEND_URL=https://your-backend.railway.app

NODE_ENV=production
